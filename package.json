{
  "name": "lap-counter",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "expo": "^56.0.12",
    "expo-background-fetch": "~56.0.19",
    "expo-dev-client": "~56.0.20",
    "expo-haptics": "~56.0.3",
    "expo-keep-awake": "~56.0.3",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-sensors": "~56.0.6",
    "expo-status-bar": "~56.0.4",
    "expo-task-manager": "~56.0.19",
    "expo-updates": "~56.0.19",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-ble-plx": "^3.5.1",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "~19.2.0",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/helpers/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-ble-plx))"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "App.tsx",
      "!src/**/__tests__/**",
      "!src/**/__mocks__/**"
    ]
  },
  "private": true
}
